# .env.example
# Copy this to .env.local for local development.
# These variables will be loaded by Docker Compose.

# Application Mode
APP_MODE=development

# Database Credentials
DB_HOST=db
DB_NAME=my_local_db
DB_USER=my_local_user
DB_PASS=replace_with_a_strong_password
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_USE_SSL=false
DB_SSL_CA=


# This is ONLY for the initial setup of the local MySQL container
MYSQL_ROOT_PASSWORD=replace_with_a_strong_root_password